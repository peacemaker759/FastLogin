{
  "manifest_version": 3,
  "name": "FastLogin",
  "version": "1.0.0",
  "description": "Удобный менеджер локальных сессий для каждого сайта с полной изоляцией по доменам.",
  "permissions": [
    "cookies",
    "storage",
    "activeTab",
    "scripting",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "fastlogin@local.ext",
      "strict_min_version": "109.0"
    }
  }
}
